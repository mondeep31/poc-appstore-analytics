# Dashboard JWT auth
JWT_SECRET=changeme_use_a_long_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Apple App Store Connect API
# Key ID from App Store Connect > Users and Access > Integrations > App Store Connect API
APPLE_KEY_ID=
# Issuer ID from the same page
APPLE_ISSUER_ID=
# Base64-encoded contents of your .p8 file: base64 -i AuthKey_XXX.p8
APPLE_PRIVATE_KEY_BASE64=
# Vendor Number from App Store Connect > Payments and Financial Reports
APPLE_VENDOR_NUMBER=
# App numeric ID — leave blank to auto-fetch from /v1/apps
APPLE_APP_ID=

# CORS
CORS_ORIGIN=http://localhost:3000
PORT=4000
