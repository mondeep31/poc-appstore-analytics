# Dashboard JWT auth
JWT_SECRET=changeme_use_a_long_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Apple App Store Connect API
# Key ID from App Store Connect > Users and Access > Integrations > App Store Connect API
APPLE_KEY_ID=
# Issuer ID from the same page
APPLE_ISSUER_ID=
# Base64-encoded contents of your .p8 file: base64 -i AuthKey_XXX.p8
APPLE_PRIVATE_KEY_BASE64=
# Vendor Number from App Store Connect > Payments and Financial Reports
APPLE_VENDOR_NUMBER=
# App numeric ID — leave blank to auto-fetch from /v1/apps
APPLE_APP_ID=

# CORS
CORS_ORIGIN=http://localhost:3000
PORT=4000

# --- Google Play bulk reports (GCS mirror via API scheduler — PLAYSTORE_DOWNLOAD_SCHEDULE_ENABLED) ---
PLAYSTORE_GCS_BUCKET=
PLAYSTORE_PACKAGE_NAME=
# PLAYSTORE_RAW_DIR=/absolute/path/to/data/playstore/raw
# Path to service account JSON for GCS (never commit this file):
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: run the same GCS download on a schedule inside the API process (node-schedule).
# Use only on a single API instance to avoid duplicate downloads.
PLAYSTORE_DOWNLOAD_SCHEDULE_ENABLED=true
# Cron: minute hour day-of-month month weekday (required when PLAYSTORE_DOWNLOAD_SCHEDULE_ENABLED is true).
PLAYSTORE_DOWNLOAD_CRON=5 18 * * *
# IANA timezone for that cron (recommended; if omitted, server local time is used).
PLAYSTORE_DOWNLOAD_TZ=Asia/Kolkata
